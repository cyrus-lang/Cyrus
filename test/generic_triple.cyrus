// @stdout: 1 3.3 3.6
// @stdin: 
// @args:

import std::libc{printf};

struct Triple<A, B, C> {
    pub x: A;
    pub y: B;
    pub z: C;

    fn display(&self) {
        printf("%d\n", 0);
    }
}

fn main() {
    var triple = Triple {
        x: 1,
        y: 3.3,
        z: 3.6float64
    };

    printf("%d %.1f %.1f\n", triple.x, triple.y, triple.z);
}
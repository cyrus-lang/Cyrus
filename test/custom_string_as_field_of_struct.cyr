// @stdout: name: Cyrus!
// @stdin: 
// @args:

import std::libc{printf, malloc, free, strncpy};
import std::string{String};

struct Foo {
    name: String;

    pub fn display(&self) {
        printf("name: %s\n", self->name);
    }

    pub fn free(&self) {
        self->name.free();
    }
}

fn main() {
    #inst = Foo {
        name: String.new("Cyrus!")
    };
    
    inst.display();
    inst.free();
}
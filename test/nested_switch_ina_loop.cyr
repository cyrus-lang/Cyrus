// @stdout: <Cyrus/> Programming Language
// @stdin: 
// @args:

import std::libc{printf};

fn main() {
    #list = char*[3] {"Cyrus", "Programming", "Language"};

    for (#i = 0; i < 3; i++) {
        switch (list[i]) {
            case "Cyrus":
                printf("<%s/> ", list[i]);
                break;
            default:
                printf("%s ", list[i]);
                break;
        }
    }
}
// @stdout: Hello, Cyrus!
// @stdin: 
// @args:

import std::libc{printf, strlen, malloc, strcpy, strcat, free};

pub fn concat(s1: const char*, s2: const char*) const char* {
    var len1: size_t = strlen(s1);
    var len2: size_t = strlen(s2);

    // +1 for null terminator
    var total: size_t = len1 + len2 + 1;

    // Allocate memory (raw C malloc)
    var result = cast(char*, malloc(total));

    strcpy(result, s1);
    strcat(result, s2);

    return result;
}

fn main() {
    var hello = "Hello, ";
    var world = "Cyrus!";
    var combined = concat(hello, world);

    printf("%s\n", combined);
    free(combined);
}
// @stdin: 
// @args:

import std::libc{printf};

pub fn fibonacci(n: int) int {
    if (n == 0) {
        return 0;
    }
    else if (n == 1) {
        return 1;
    }
    else {
        return fibonacci(n - 1) + fibonacci(n - 2);
    }
}

fn main() {
    printf("%d\n", fibonacci(6));
}

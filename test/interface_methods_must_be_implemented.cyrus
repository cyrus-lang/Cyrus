// @stdout: Student Taha 18
// @stdin: 
// @args:

import std::libc{printf};

interface Person {
    fn display(&self) void;
}

interface Debug {
    fn fmt(&self) char*;
}

struct Student : Person, Debug {
    name: char*;
    age: uint;

    pub fn display(&self) {
        printf("%s ", self->fmt());
        printf("%s ", self->name);
        printf("%d", self->age);
    }

    pub fn fmt(&self) char* {
        return "Student";
    }
}

fn main() {
    var inst = Student {
        name: "Taha",
        age: 18
    };

    inst.display();
}
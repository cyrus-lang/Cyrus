extern func printf(format: const char*, ...);
extern func exit(status: int);

public func eval_fibonacci(n: int32) int32 {
    if (n == 0) {
        return 0;
    }
    else if (n == 1) {
        return 1;
    }
    else {
        return eval_fibonacci(n - 1) + eval_fibonacci(n - 2);
    }
}

func main() {
    for (#i = 0; i < 30; i++) {
        printf("%d\n", eval_fibonacci(i));
    }
}

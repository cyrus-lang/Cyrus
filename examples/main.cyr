import std::libc{printf, malloc};

struct Item {
    public bar: int;
}

struct Foo {
    public values: Item[3];
    public truth: int*;
}

func main() {
    #a = 666;
    #foo = Foo {
        values: Item[3] {
            Item { bar: 10 },
            Item { bar: 20 },
            Item { bar: 30 },
        },
        truth: &a
    };

    #foo_ref = &foo;

    if (!foo_ref->truth) {
        printf("here we are\n");
    } else {
        printf("bitch\n");
    }
}

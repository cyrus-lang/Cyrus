import std::string{String};
import std::libc{printf, malloc};

struct Foo {
    name: String;

    public func bar(&self) {
        printf("name: %s\n", self->name.c_str());
    }
}

struct Sample {
    foo: Foo;
}

func main() {
    #inst = Sample { foo: Foo { name: String.new("Taha") } };
    inst.foo.name.free();
    inst.foo.name = String.new("Changed!");
    inst.foo.bar();
}


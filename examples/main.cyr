import std::libc{printf, malloc, free, strncpy};

struct Sample {
	name: char*;
    age: int;
}

func display_columns(schema: Sample*) {
	printf("name %s\n", schema[0].name);
	printf("name %s\n", schema[1].name);
}

func main() {
	#columns = Sample[3] {
		Sample { name: "id", age: 18 },
		Sample { name: "name", age: 19 },
		Sample { name: "age", age: 20 },
	};

	display_columns(&columns);
}
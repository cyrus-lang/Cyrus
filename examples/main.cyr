import std::libc{printf}; 

enum Color {
    Red,
    Green,
    Black,
    Valued = "my valued color!",
    Custom(int, int)
}

func main() {
    #variant = Color.Valued;

    switch (variant) {
        case .Red:   
            printf("Red\n");
            break;
        case .Black: 
            printf("Black\n");
            break;
        case .Valued: 
            printf("Valued\n");
            break;
        default:     
            printf("Unknown\n");
            break;
    }
}
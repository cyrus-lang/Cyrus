import std::libc{printf, malloc};

public enum DataType {
    Int,
    Text
}

public union ValueData {
    int_value: int;
    text_value: char*;
}

public struct Value {
    public v: int;
}

public struct Row { 
    public values: Value*;
}

public struct Column {
    public name: char[64];
}

func main() {
    #row: Row = Row { values: cast(Value*, malloc(sizeof(Value))) };
    row.values[0].v = 0;
    
}
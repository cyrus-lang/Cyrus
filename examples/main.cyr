import std::libc{printf, malloc, free, strncpy};

MAX_STR_LEN: const size_t = 64;

struct Foo {
    name: char*; // alloc
}

func do(input: char*) {
    #inst: Foo;

    inst.name = cast(char*, malloc(MAX_STR_LEN));
    strncpy(inst.name, input, MAX_STR_LEN - 1);

    printf("name: %s\n", inst.name);
    free(inst.name);
}

func main() {
    #a = "Hello, Cyrus!";
    do(a);
}


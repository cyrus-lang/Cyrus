import std::libc{printf};

struct Sample {
    a: void*;
}

// PI: void*; // FIXME

func main() {
    #a = 10;
    #sample = Sample { a: null };
    #ptr = &sample;

    if (sample.a == null) {
        printf("null a\n");
    }

    if (ptr->a == null) {
        printf("null aaaaaaa\n");
    }

    printf("end\n");
}
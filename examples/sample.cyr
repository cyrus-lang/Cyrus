extern func printf(format: const char*, ...);

public PI = 3.14;

public func hello() {
    printf("Hello, Cyrus!\n");
}

public func sample() {
    printf("Sample!\n");
    printf("PI: %f!\n", PI);
}

struct Person {
    name: char*;
    age: uint;

    func display(self) {
        printf("name: %s\n", self.get_name());
        printf("age: %d\n", self.age);
    }

    func get_name(self) char* {
        return self.name;
    }
}

type MyPerson = Person;
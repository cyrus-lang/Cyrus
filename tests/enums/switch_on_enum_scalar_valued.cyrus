// @stdout: a(10) b(20) c(30)

import std::libc{printf};

enum ScalarEnum {
    A = 10, 
    B = 20,
    C = 30
}

fn display_kind(value: ScalarEnum) {
	switch (value) {
		case .A(a) => {
			printf("a(%d) ", a);
		}
		case .B(b) => {
			printf("b(%d) ", b);
		}
		case .C(c) => {
			printf("c(%d) ", c);
		}
	}
}

pub fn main() {
	const x: ScalarEnum = .A;

    display_kind(x);
    display_kind(.B);
    display_kind(.C);
}

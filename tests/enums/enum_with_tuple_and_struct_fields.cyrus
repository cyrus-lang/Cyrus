// @stdout: FileNotFound(reason: I don't know:/) | FileEmpty(tuple: (4, 5)) | NoPermission(value: 99) |

import std::libc{printf};

enum FileReadError {
    FileNotFound(struct {
        why: char*
    }),
    NoPermission(usize),
    FileEmpty((usize, usize))
}

fn display_file_read_error(f: FileReadError) {
    switch (f) {
        case .FileNotFound(reason) => {
            printf("FileNotFound(reason: %s) | ", reason.why);
        }
        case .NoPermission(value) => {
            printf("NoPermission(value: %d) | ", value);
        }
        case .FileEmpty(tuple) => {
            printf("FileEmpty(tuple: (%d, %d)) | ", tuple.0, tuple.1);
        }
        default => {
            printf("UnknownFileReadError | ");
        }
    }
}

pub fn main() {
    var f = FileReadError.FileNotFound(struct { why = "I don't know:/" });
    display_file_read_error(f);

    f = FileReadError.FileEmpty((4, 5));
    display_file_read_error(f);

    f = FileReadError.NoPermission(99);
    display_file_read_error(f);
}

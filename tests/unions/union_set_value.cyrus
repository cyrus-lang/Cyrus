// @stdout: Cyrus!

import std::libc{printf};

union Value {
    text_value: char*;
    int_value: int64;
}

fn set_union_value(inst: Value) {
    inst.text_value = "changed";
}

pub fn main() {
    const inst = Value { text_value: "Cyrus!" };

    // pass by value
    set_union_value(inst);

    printf("%s\n", inst.text_value);
}
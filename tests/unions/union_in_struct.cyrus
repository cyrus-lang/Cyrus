// @stdout: integer: 42 string: hello

import std::libc{printf};

union Data {
    int_val: int32,
    str_val: uint8*
}

struct Container {
    pub tag: uint8*,
    pub data: Data
}

pub fn main() {
    var c = Container { tag: "integer", data: Data { int_val: 42 } };
    printf("integer: %d ", c.data.int_val);

    c.data.str_val = "hello";
    printf("string: %s\n", c.data.str_val);
}

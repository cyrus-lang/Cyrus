// @stdout: 10

import std::libc{printf};

struct Box<T> {
    pub value: T;

    pub fn new(value: T) Self {
        return Self { value };
    }
}

struct Integer {
    pub box: Box<int>;

    pub fn new(value: int) Self {
        const box = Box.new(value);

        return Self { box };
    }
}

pub fn main() {
    const integer = Integer.new(10);
    
    printf("%d\n", integer.box.value);
}
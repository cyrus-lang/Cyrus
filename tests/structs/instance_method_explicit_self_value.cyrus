import std::libc{printf};

struct Person {
    name: char*;
    age: uint;

    pub fn display(&self) {
        printf("%s %d\n", self->name, self->age);
    }
}

pub fn main() {
    const person = struct {
        name: "Taha",
        age: 18uint
    };
    
    Person.display(&person);
}
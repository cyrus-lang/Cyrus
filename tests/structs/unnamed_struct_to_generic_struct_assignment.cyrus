// @stdout: 15 6.280000 x

import std::libc{printf};

struct MyGenericStruct<K, V, H> {
    pub a: K;
    pub b: V;
    pub c: H;
}

pub fn main() {
    var inst = MyGenericStruct { a: 10, b: 3.14, c: 'z' };

    inst = struct {
        a = inst.a + 5,
        b = inst.b * 2.0,
        c = inst.c = 'x'
    };
    
    printf("%d %f %c", inst.a, inst.b, inst.c);
}
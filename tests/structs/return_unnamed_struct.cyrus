// @stdout: Taha 18

import std::libc{printf};

fn new_person(name: char*, age: uint32) struct { name: char*, age: uint32 } {
    return struct {
        name = name,
        age = age
    };
}

pub fn main() {
    const person = new_person("Taha", 18);
    printf("%s %d\n", person.name, person.age);
}
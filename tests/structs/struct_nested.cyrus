// @stdout: Cyrus 42

import std::libc{printf};

struct Inner {
    pub value: int
}

struct Outer {
    pub name: char*,
    pub inner: Inner
}

pub fn main() {
    const obj = Outer {
        name: "Cyrus",
        inner: Inner {
            value: 42
        }
    };

    printf("%s %d\n", obj.name, obj.inner.value);
}

// @stdout: A:1 xx B:2

import std::libc{printf};

struct Person {
    name: char*;
    age: uint;

    pub fn display(&self) {
        printf("%s:%d", self->name, self->age);
    }

    pub fn pipe() {
        printf(" xx ");
    }
}

pub fn main() {
    const person1 = Person { name: "A", age: 1 };
    person1.display();

    Person.pipe();

    const person2 = struct { name = "B", age = 2 };
    Person.display(&person2);
}
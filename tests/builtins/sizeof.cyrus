// @stdout: 4 8 16 8 12

import std::libc{printf};

pub fn main() {
    printf("%d ", @sizeOf(int)); // works 
    printf("%d ", @sizeOf(float64)); // works 
    printf("%d ", @sizeOf(struct { a: int*, b: int32* })); 
    printf("%d ", @sizeOf(enum(int64) { A, B }));   
    printf("%d ", @sizeOf(struct { c: int, x: struct { a: int }, a: int }));
}
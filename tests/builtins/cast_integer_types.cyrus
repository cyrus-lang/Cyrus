// @stdout: 100 1000 100000 10000000000 -1 -1 -1 10000000000

import std::libc{printf};

pub fn main() {
    var i8_val: int8 = 100;
    var i16_val: int16 = 1000;
    var i32_val: int32 = 100000;
    var i64_val: int64 = 10000000000;

    printf("%d ", @cast(int32, i8_val));
    printf("%d ", @cast(int32, i16_val));
    printf("%d ", i32_val);
    printf("%lld ", i64_val);

    var u8_val: uint8 = 255;
    var u16_val: uint16 = 65535;
    var u32_val: uint32 = 4294967295;
    var u64_val: uint64 = 10000000000;

    printf("%d ", @cast(int32, u8_val));
    printf("%d ", @cast(int32, u16_val));
    printf("%d ", @cast(int32, u32_val));
    printf("%lld\n", @cast(int64, u64_val));
}

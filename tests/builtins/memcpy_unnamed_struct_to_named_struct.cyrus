// @stdout: name: Cyrus, age: 2500

import std::libc{printf};

struct Data {
    pub name: uint8*,
    pub age: uint
}

pub fn main() {
    var dst: Data;
    var src = struct {
        name: "Cyrus",
        age: 2500
    };

    @memcpy(&dst, &src, @sizeof(Data));

    printf("name: %s, age: %d\n", dst.name, dst.age);
}
// @stdout: meow 

import std::libc{printf};

interface Animal {
    fn bark(&const self) const uint8*;
}

struct Cat : Animal {
    fn bark(&const self) const uint8* {
        return "meow";
    }
}

fn my_cat() Animal {
    return dynamic Cat{};
}

pub fn main() {
    const animal = my_cat();
    
    printf("%s\n", animal.bark());
}
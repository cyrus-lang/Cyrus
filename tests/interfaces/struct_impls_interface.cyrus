// @stdout: 5

import std::libc{printf, malloc, free};

interface Allocator {
    fn alloc(&self, size: usize) void*;
    fn free(&self, ptr: void*) void;
}

struct HeapAllocator : Allocator {
    pub fn new() Self {
        return Self {};
    }

    pub fn alloc(&self, size: usize) void* {
        return malloc(size);
    }

    pub fn free(&self, ptr: void*) void {
        free(ptr);
    }
}

pub fn main() {
    const allocator = HeapAllocator.new();
    
    var ptr: int* = allocator.alloc(4);
    
    *ptr = 5;
    printf("%d\n", *ptr);
    allocator.free(ptr);
}
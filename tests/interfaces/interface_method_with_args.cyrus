// @stdout: 120
import std::libc{printf};

interface Calculator {
    fn compute(&const self, x: int) int;
}

struct Factorial : Calculator {
    pub fn compute(&const self, x: int) int {
        if (x <= 1) {
            return 1;
        }
        return x * self->compute(x - 1);
    }
}

pub fn main() {
    const calc: Calculator = dynamic Factorial{};
    printf("%d\n", calc.compute(5));
}

// @stdout: this is meow :3 meow بعععع

import std::libc{printf};

interface Animal {
	fn sound(&const self) const char*;
}

struct Cat : Animal {
	pub fn sound(&const self) const char* {
		return "meow";
	}

    pub fn introduce(&const self) {
        printf("this is meow :3");
    }
}

struct Ship : Animal {
    fn sound(&const self) const char* {
		return "بعععع";
	}   
}

pub fn main() {
	const cat = Cat {};
    cat.introduce();

    const animals = Animal[2]{dynamic cat, dynamic Ship{}};
	printf(" %s %s\n", animals[0].sound(), animals[1].sound());
}
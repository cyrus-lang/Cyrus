// @stdout: 1234 1122871810 3735928559 42 255 42 127 9223372036854775807

import std::libc { printf };

pub fn main() {
    const decimal = 1234;
    printf("%d ", decimal);

    const hex_val = 0x42EDAA02uint32; 
    printf("%u ", hex_val);

    const hex_underscores = 0xDE_AD_BE_EFuint32;
    printf("%u ", hex_underscores);

    const binary_val = 42;
    printf("%d ", binary_val);

    const u8_val = 0xFFuint8; 
    printf("%d ", u8_val);

    const decimal_binary = 0b101010;
    printf("%d ", decimal_binary);

    const i7_val = 127int8;
    printf("%d ", i7_val);

    const i64_max = 9223372036854775807int64;
    printf("%lld\n", i64_max);
}
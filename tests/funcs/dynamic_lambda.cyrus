// @stdout: 3

import std::libc{printf};

pub fn main() {
    var x = true;

    var lambda: fn(int64) int64 = fn(_x: int64) int64 { return -1; };
    if (!!x) {
        lambda = fn(x: int64) int64 { return x + 1; };
    } else {
        lambda = fn(x: int64) int64 { return -x; };
    }

    printf("%d\n", lambda(2));
}
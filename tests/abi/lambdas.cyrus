import std::libc{printf};
import std::libc::abi{c_int, c_double};

type CallbackFn = fn(c_int, c_double) c_double;

const handler = fn(x: c_int, y: c_double) c_double {
    return cast(c_double, x) + y;
};

extern "C" fn call_callback_fn(cbk: CallbackFn);

pub fn main() {
    call_callback_fn(handler);
}
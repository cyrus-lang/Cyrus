// @stdout: 7.000000 4.000000 15

import std::libc{printf};

struct MathUtils {
    pub fn add<T>(x: T, y: T) T {
        return x + y;
    }

    pub fn sub<T>(x: T, y: T) T {
        return x - y;
    }

    pub fn mul<T>(x: T, y: T) T {
        return x * y;
    }
}

pub fn main() {    
    printf("%f ", MathUtils<float64>.add(5.5, 1.5));
    printf("%f ", MathUtils.sub(5.5, 1.5));
    printf("%d ", MathUtils.mul(3, 5));
}
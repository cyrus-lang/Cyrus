// @stdout: 99 

import std::libc{printf, malloc, free};

struct Box<T> {
    raw: T*;

    pub fn new(raw: T*) Self {
        return Self { raw: raw };
    }

    pub fn raw_ptr(&self) T* {
        return self->raw;
    }
}

pub fn main() {
    var raw: int* = malloc(4);
    
    *raw = 99;

    const box = Box.new(raw);
    
    printf("%d\n", *raw);
    free(box.raw_ptr());
}

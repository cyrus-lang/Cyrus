// @stdout: Value! 2 0

import std::libc{printf};

struct IOError<V, E = uint64> {
    pub value: V;
    pub error: E;

    pub fn new(const value: V, const error: E) Self {
        return Self { value, error };
    }

    pub fn display_error(const self) {
        printf("%d ", self.error);
    }

    pub fn display_value(const self) {
        printf("%s ", self.value);
    }

    pub fn set_error(&self, const new_error: E) {
        self->error = new_error;
    }

    pub fn get_error(&const self) E {
        return self->error;
    }
}

pub fn main() {
    var inst = IOError.new("Value!", 2);
    inst.display_value();
    inst.display_error();

    inst.set_error(0);
    inst.display_error();
}
// @stdout: Hello World, 11

import std::mem::alloc::libc{LibcAllocator};
import std::mem{Allocator};
import std::string{String};
import std::libc{printf};

pub fn main() {
    const allocator: Allocator = dynamic LibcAllocator.new();

    var name = String.from_str(allocator, "   Hello World    ");
    defer name.free();

    name.trim();

    const str = name.as_str_const();

    for (var i: usize = 0; i < name.len(); i++) {
        printf("%c", str[i]);
    }

    printf(", %d\n", name.len());
}
// @stdout: ABC

import std::libc{printf};

pub fn main() {
    const arr = int32[3]{1, 2, 3};
    
    for (var i: usize = 0; i < 3; i++) {
        const item = arr[i];

        switch (item) {
            case 1 => {
                printf("A");
            }
            case 2 => {
                printf("B");
            }
            case 3 => {
                printf("C");
            }
            default => {
                printf("unknown");
            }
        }
    }
}
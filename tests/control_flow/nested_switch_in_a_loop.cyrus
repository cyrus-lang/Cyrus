// @stdout: ABC

import std::libc{printf};

fn main() {
    const arr = int[3]{1, 2, 3};
    const len = sizeof(arr) / sizeof(arr[0]);
    
    for (var i: size_t = 0; i < len; i++) {
        const item = arr[i];

        switch (item) {
            case 1 => {
                printf("A");
            }
            case 2 => {
                printf("B");
            }
            case 3 => {
                printf("C");
            }
            default => {
                printf("unknown");
            }
        }
    }
}
// @stdout: 0 1 3 4 \n0 1 2 3 4 5 6 \n10\n24

import std::libc{printf};

pub fn main() {
    var i: int32 = 0;

    while (i < 5) {
        if (i == 2) {
            i++;
            continue;
        }
        printf("%d ", i);
        i++;
    }
    printf("\n");

    var j: int32 = 0;
    while (j < 10) {
        if (j == 7) {
            break;
        }
        printf("%d ", j);
        j++;
    }
    printf("\n");

    var sum: int32 = 0;
    var k: int32 = 1;
    while (k <= 4) {
        sum = sum + k;
        k++;
    }
    printf("%d\n", sum);

    var acc: int32 = 1;
    var m: int32 = 1;
    while (m <= 4) {
        acc = acc * m;
        m++;
    }
    printf("%d\n", acc);
}

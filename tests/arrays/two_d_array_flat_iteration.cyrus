// @stdout: 1 2 3 4 5 6 7 8 9

import std::libc{printf};

pub fn main() {
    var x: int32[3][3] = int32[3][3]{
        int32[3]{1, 2, 3},
        int32[3]{4, 5, 6},
        int32[3]{7, 8, 9},
    };

    var ptr: int32* = &x[0][0];
    for (var i: int32 = 0; i < 9; i++) {
        printf("%d ", *(ptr + i));
    }
    printf("\n");
}

// @stdout: Cyrus

import std::libc{printf};

type const_str = uint8*;

fn mutate_const_str(str: const_str*) {
    *str = "Cyrus";
}

fn display_const_str(str: const_str) {
    printf("%s\n", str);
}

pub fn main() {
    const name: uint8* = "unknown";

    mutate_const_str(&name);
    display_const_str(name);
}
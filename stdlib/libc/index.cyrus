// locale

pub repr(c) struct CLocaleConv {
    decimal_point: types::c_char*;
    thousands_sep: types::c_char*;
    grouping: types::c_char*;
    int_curr_symbol: types::c_char*;
    currency_symbol: types::c_char*;
    mon_decimal_point: types::c_char*;
    mon_thousands_sep: types::c_char*;
    mon_grouping: types::c_char*;
    positive_sign: types::c_char*;
    negative_sign: types::c_char*;
    int_frac_digits: types::c_char;
    frac_digits: types::c_char;
    p_cs_precedes: types::c_char;
    p_sep_by_space: types::c_char;
    n_cs_precedes: types::c_char;
    n_sep_by_space: types::c_char;
    p_sign_posn: types::c_char;
    n_sign_posn: types::c_char;
    int_p_cs_precedes: types::c_char;
    int_p_sep_by_space: types::c_char;
    int_n_cs_precedes: types::c_char;
    int_n_sep_by_space: types::c_char;
    int_p_sign_posn: types::c_char;
    int_n_sign_posn: types::c_char;
}

pub extern "C" {
    fn setlocale(category: types::c_int, locale: types::c_char*) types::c_char*;
    fn localeconv() CLocaleConv*;
}


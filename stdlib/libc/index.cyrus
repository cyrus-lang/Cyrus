// time 

pub repr(c) struct CTimeSpec {
    tv_sec: types::c_long;
    tv_nsec: types::c_long;
}

pub repr(c) struct CTimeVal {
    tv_sec: types::c_long;
    tv_usec: types::c_long;
}

pub repr(c) struct CTm {
    tm_sec: types::c_int;
    tm_min: types::c_int;
    tm_hour: types::c_int;
    tm_mday: types::c_int;
    tm_mon: types::c_int;
    tm_year: types::c_int;
    tm_wday: types::c_int;
    tm_yday: types::c_int;
    tm_isdst: types::c_int;
    tm_gmtoff: types::c_long;
    tm_zone: types::c_char*;
}

pub extern "C" {
    fn clock() types::c_long;
    fn difftime(time1: types::c_long, time0: types::c_long) types::c_double;
    fn mktime(tm: CTm*) types::c_long;
    fn time(timer: types::c_long*) types::c_long;

    fn asctime(tm: CTm*) types::c_char*;
    fn ctime(timer: types::c_long*) types::c_char*;

    fn gmtime(timer: types::c_long*) CTm*;
    fn localtime(timer: types::c_long*) CTm*;

    fn gmtime_r(timer: types::c_long*, result: CTm*) CTm*;
    fn localtime_r(timer: types::c_long*, result: CTm*) CTm*;

    fn strftime(
        s: types::c_char*,
        max: types::c_size,
        format: types::c_char*,
        tm: CTm*
    ) types::c_size;

    fn timespec_get(ts: CTimeSpec*, base: types::c_int) types::c_int;
}

// signal 

pub type CSignalHandler = fn(types::c_int) types::c_void;

pub extern "C" {
    fn signal(sig: types::c_int, handler: CSignalHandler) CSignalHandler;
    fn raise(sig: types::c_int) types::c_int;
}


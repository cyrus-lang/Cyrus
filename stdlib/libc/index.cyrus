import std::libc::types;

// stdio

pub extern "C" {
    var stdin:  types::c_file*;
    var stdout: types::c_file*;
    var stderr: types::c_file*;

    fn printf(format: types::c_char*, ...) types::c_int;
    fn fprintf(stream: types::c_file*, format: types::c_char*, ...) types::c_int;
    fn sprintf(str: types::c_char*, format: types::c_char*, ...) types::c_int;
    fn snprintf(str: types::c_char*, size: types::c_size, format: types::c_char*, ...) types::c_int;

    fn vprintf(format: types::c_char*, ap: types::c_va_list) types::c_int;
    fn vfprintf(stream: types::c_file*, format: types::c_char*, ap: types::c_va_list) types::c_int;
    fn vsprintf(str: types::c_char*, format: types::c_char*, ap: types::c_va_list) types::c_int;
    fn vsnprintf(str: types::c_char*, size: types::c_size, format: types::c_char*, ap: types::c_va_list) types::c_int;

    fn scanf(format: types::c_char*, ...) types::c_int;
    fn fscanf(stream: types::c_file*, format: types::c_char*, ...) types::c_int;
    fn sscanf(str: types::c_char*, format: types::c_char*, ...) types::c_int;

    fn vscanf(format: types::c_char*, ap: types::c_va_list) types::c_int;
    fn vfscanf(stream: types::c_file*, format: types::c_char*, ap: types::c_va_list) types::c_int;
    fn vsscanf(str: types::c_char*, format: types::c_char*, ap: types::c_va_list) types::c_int;

    fn getchar() types::c_int;
    fn putchar(ch: types::c_int) types::c_int;

    fn getc(stream: types::c_file*) types::c_int;
    fn putc(ch: types::c_int, stream: types::c_file*) types::c_int;

    fn fgetc(stream: types::c_file*) types::c_int;
    fn fputc(ch: types::c_int, stream: types::c_file*) types::c_int;

    fn ungetc(ch: types::c_int, stream: types::c_file*) types::c_int;

    fn fgets(str: types::c_char*, n: types::c_int, stream: types::c_file*) types::c_char*;
    fn fputs(str: types::c_char*, stream: types::c_file*) types::c_int;
    fn puts(str: types::c_char*) types::c_int;
    fn fread(ptr: types::c_void*, size: types::c_size, nmemb: types::c_size, stream: types::c_file*) types::c_size;
    fn fwrite(ptr: types::c_void*, size: types::c_size, nmemb: types::c_size, stream: types::c_file*) types::c_size;

    fn fopen(filename: types::c_char*, mode: types::c_char*) types::c_file*;
    fn freopen(filename: types::c_char*, mode: types::c_char*, stream: types::c_file*) types::c_file*;
    fn fclose(stream: types::c_file*) types::c_int;

    fn remove(filename: types::c_char*) types::c_int;
    fn rename(old: types::c_char*, new: types::c_char*) types::c_int;

    fn tmpfile() types::c_file*;
    fn tmpnam(str: types::c_char*) types::c_char*;

    fn fflush(stream: types::c_file*) types::c_int;

    fn setbuf(stream: types::c_file*, buf: types::c_char*) types::c_void;
    fn setvbuf(stream: types::c_file*, buf: types::c_char*, mode: types::c_int, size: types::c_size) types::c_int;

    fn fseek(stream: types::c_file*, offset: types::c_long, whence: types::c_int) types::c_int;
    fn ftell(stream: types::c_file*) types::c_long;
    fn rewind(stream: types::c_file*) types::c_void;

    fn fgetpos(stream: types::c_file*, pos: types::c_fpos*) types::c_int;
    fn fsetpos(stream: types::c_file*, pos: types::c_fpos*) types::c_int;

    fn feof(stream: types::c_file*) types::c_int;
    fn ferror(stream: types::c_file*) types::c_int;
    fn clearerr(stream: types::c_file*) types::c_void;
    fn perror(s: types::c_char*) types::c_void;

    fn flockfile(stream: types::c_file*) types::c_void;
    fn ftrylockfile(stream: types::c_file*) types::c_int;
    fn funlockfile(stream: types::c_file*) types::c_void;

    fn fileno(stream: types::c_file*) types::c_int;
    fn getline(lineptr: types::c_char**, n: types::c_size*, stream: types::c_file*) types::c_ssize;
}

// stdlib

pub repr(c) struct CDivResult {
    quot: types::c_int;
    rem: types::c_int;
}

pub repr(c) struct CLongDivResult {
    quot: types::c_long;
    rem: types::c_long;
}

pub repr(c) struct CLongLongDivResult {
    quot: types::c_long_long;
    rem: types::c_long_long;
}

pub extern "C" {
    fn atof(nptr: types::c_char*) types::c_double;
    fn atoi(nptr: types::c_char*) types::c_int;
    fn atol(nptr: types::c_char*) types::c_long;
    fn atoll(nptr: types::c_char*) types::c_long_long;

    fn strtod(nptr: types::c_char*, endptr: types::c_char**) types::c_double;
    fn strtof(nptr: types::c_char*, endptr: types::c_char**) types::c_float;
    fn strtol(nptr: types::c_char*, endptr: types::c_char**, base: types::c_int) types::c_long;
    fn strtoul(nptr: types::c_char*, endptr: types::c_char**, base: types::c_int) types::c_unsigned_long;
    fn strtoll(nptr: types::c_char*, endptr: types::c_char**, base: types::c_int) types::c_long_long;
    fn strtoull(nptr: types::c_char*, endptr: types::c_char**, base: types::c_int) types::c_unsigned_long_long;

    // FIXME: requires c_long_double but it's not implemented yet.
    // fn strtold(nptr: types::c_char*, endptr: types::c_char**) types::c_long_double;

    fn rand() types::c_int;
    fn srand(seed: types::c_uint) types::c_void;

    fn malloc(size: types::c_size) types::c_void*;
    fn calloc(nmemb: types::c_size, size: types::c_size) types::c_void*;
    fn realloc(ptr: types::c_void*, size: types::c_size) types::c_void*;
    fn free(ptr: types::c_void*) types::c_void;

    fn aligned_alloc(alignment: types::c_size, size: types::c_size) types::c_void*;

    fn posix_memalign(memptr: types::c_void**, alignment: types::c_size, size: types::c_size) types::c_int;

    fn abort() types::c_void;
    fn exit(status: types::c_int) types::c_void;
    fn _Exit(status: types::c_int) types::c_void;

    fn atexit(func: fn() types::c_void) types::c_int;

    fn quick_exit(status: types::c_int) types::c_void;
    fn at_quick_exit(func: fn() types::c_void) types::c_int;

    fn getenv(name: types::c_char*) types::c_char*;
    fn system(command: types::c_char*) types::c_int;

    fn bsearch(
        key: types::c_void*,
        base: types::c_void*,
        nmemb: types::c_size,
        size: types::c_size,
        compar: fn(types::c_void*, types::c_void*) types::c_int
    ) types::c_void*;

    fn qsort(
        base: types::c_void*,
        nmemb: types::c_size,
        size: types::c_size,
        compar: fn(types::c_void*, types::c_void*) types::c_int
    ) types::c_void;

    fn abs(j: types::c_int) types::c_int;
    fn labs(j: types::c_long) types::c_long;
    fn llabs(j: types::c_long_long) types::c_long_long;

    fn div(numer: types::c_int, denom: types::c_int) CDivResult;
    fn ldiv(numer: types::c_long, denom: types::c_long) CLongDivResult;
    fn lldiv(numer: types::c_long_long, denom: types::c_long_long) CLongLongDivResult;

    fn mblen(s: types::c_char*, n: types::c_size) types::c_int;
    fn mbtowc(pwc: types::c_wchar*, s: types::c_char*, n: types::c_size) types::c_int;
    fn wctomb(s: types::c_char*, wc: types::c_wchar) types::c_int;

    fn mbstowcs(
        dest: types::c_wchar*,
        src: types::c_char*,
        n: types::c_size
    ) types::c_size;

    fn wcstombs(
        dest: types::c_char*,
        src: types::c_wchar*,
        n: types::c_size
    ) types::c_size;
}

// string

pub extern "C" {
    fn memcpy(
        dest: types::c_void*,
        src: types::c_void*,
        n: types::c_size
    ) types::c_void*;

    fn memmove(
        dest: types::c_void*,
        src: types::c_void*,
        n: types::c_size
    ) types::c_void*;

    fn memset(
        s: types::c_void*,
        c: types::c_int,
        n: types::c_size
    ) types::c_void*;

    fn memcmp(
        s1: types::c_void*,
        s2: types::c_void*,
        n: types::c_size
    ) types::c_int;

    fn memchr(
        s: types::c_void*,
        c: types::c_int,
        n: types::c_size
    ) types::c_void*;

    fn strlen(s: types::c_char*) types::c_size;

    fn strcpy(
        dest: types::c_char*,
        src: types::c_char*
    ) types::c_char*;

    fn strncpy(
        dest: types::c_char*,
        src: types::c_char*,
        n: types::c_size
    ) types::c_char*;

    fn strcat(
        dest: types::c_char*,
        src: types::c_char*
    ) types::c_char*;

    fn strncat(
        dest: types::c_char*,
        src: types::c_char*,
        n: types::c_size
    ) types::c_char*;

    fn strcmp(
        s1: types::c_char*,
        s2: types::c_char*
    ) types::c_int;

    fn strncmp(
        s1: types::c_char*,
        s2: types::c_char*,
        n: types::c_size
    ) types::c_int;

    fn strchr(
        s: types::c_char*,
        c: types::c_int
    ) types::c_char*;

    fn strrchr(
        s: types::c_char*,
        c: types::c_int
    ) types::c_char*;

    fn strstr(
        haystack: types::c_char*,
        needle: types::c_char*
    ) types::c_char*;

    fn strpbrk(
        s: types::c_char*,
        accept: types::c_char*
    ) types::c_char*;

    fn strspn(
        s: types::c_char*,
        accept: types::c_char*
    ) types::c_size;

    fn strcspn(
        s: types::c_char*,
        reject: types::c_char*
    ) types::c_size;

    fn strtok(
        str: types::c_char*,
        delim: types::c_char*
    ) types::c_char*;

    fn strerror(errnum: types::c_int) types::c_char*;

    fn strdup(s: types::c_char*) types::c_char*;

    fn strndup(
        s: types::c_char*,
        n: types::c_size
    ) types::c_char*;
}


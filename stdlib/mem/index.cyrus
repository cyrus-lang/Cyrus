import std::libc;

pub interface Allocator {
	fn alloc(&const self, size: usize) void*;
	fn alloc_zeroed(&const self, size: usize) void*;
	fn alloc_aligned(&const self, size: usize, align: usize) void*;
	fn realloc(&const self, ptr: void*, size: usize) void*;
	fn free(&const self, ptr: void*) void;
}

pub struct LibcAllocator : Allocator {
	pub inline fn new() Self {
		return Self {};
	}

	pub inline fn alloc(&self, size: usize) void* {
		return libc::malloc(size);
	}

	pub inline fn alloc_aligned(&self, size: usize, align: usize) void* {
		@assert(is_power_of_two(align), "alignment must be power of two");
		@assert(align >= @sizeof(void*), "alignment must be >= sizeof(void*)");

		var ptr: void* = null;

		const result = libc::posix_memalign(&ptr, align, size);

		if (result != 0) {
			return null;
		}

		return ptr;
	}

	pub inline fn alloc_zeroed(&self, size: usize) void* {
		return libc::calloc(1, size);
	}

	pub inline fn realloc(&self, ptr: void*, size: usize) void* {
		return libc::realloc(ptr, size);
	}

	pub inline fn free(&self, ptr: void*) {
		libc::free(ptr);
	}
}

pub struct BumpAllocator : Allocator {
	ptr: void*;
	cap: usize;
	offset: usize;

	pub inline fn new(ptr: void*, size: usize) Self {
		return Self{
			ptr: ptr,
			cap: size,
			offset: 0
		};
	}

	pub inline fn alloc(&self, size: usize) void* {
		const current = self->offset;
		const next = current + size;

		if (next > self->cap) {
			return null;
		}

		const ptr = @cast(uintptr, self->ptr) + self->offset;
		self->offset = next;

		return @cast(void*, ptr);
	}

	pub inline fn alloc_aligned(&self, size: usize, align: usize) void* {
		@assert(is_power_of_two(align));

		const current = @cast(uintptr, self->ptr) + self->offset;
		
		const aligned = align_up(current, align);

		const new_offset = (aligned - @cast(uintptr, self->ptr)) + size;

		if (new_offset > self->cap) {
			return null;
		}

		self->offset = new_offset;

		return @cast(void*, aligned);
	}

	pub inline fn alloc_zeroed(&self, size: usize) void* {
		const ptr = self->alloc(size);

		if (ptr != null) {
			@memset(ptr, 0, size);
		}

		return ptr;
	}

	pub inline fn realloc(&self, ptr: void*, size: usize) void* {
		return null;
	}

	pub inline fn reset(&self) {
		self->offset = 0;
	}

	pub inline fn free(&self, ptr: void*) void {
		// no-operation
	}
}

pub inline fn align_up(ptr: uintptr, align: usize) uintptr {
	@assert(is_power_of_two(align), "alignment must be power of two");
	
	return (ptr + (align - 1)) & ~(align - 1);
}

pub inline fn is_power_of_two<T>(v: T) bool {
	return v != 0 && (v & (v - 1)) == 0;
}
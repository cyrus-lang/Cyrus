import std::collections::linked_list{SinglyLinkedList, SinglyNode};
import std::mem{Allocator, align_up};

pub const ARENA_DEFAULT_ALIGNMENT = @sizeof(usize); // PTR SIZE

struct ArenaNode {
	pub ptr: void*,
	pub capacity: usize,
	pub used: usize,
}

pub struct ArenaAllocator : Allocator {
    child_allocator: Allocator,
	nodes: SinglyLinkedList<ArenaNode>,

	pub fn new(const child_allocator: Allocator, const capacity: usize) Self {
        var nodes: SinglyLinkedList<ArenaNode> = SinglyLinkedList.new();
        var arena = Self { child_allocator, nodes };
        arena.create_node(capacity);
        return arena;
	}

    pub fn alloc(&self, size: usize) void* {
        return self->alloc_aligned(size, ARENA_DEFAULT_ALIGNMENT);
    }

    fn alloc_aligned(&self, size: usize, align: usize) void* {
        switch (self->nodes.peek_first()) {
            case .Some(node) => {
                var arena = &node->value;
                var ptr = arena->ptr;

                var offset = align_up(@cast(uintptr, ptr), align);

                self->ensure_capacity(offset);
                arena->used += offset;
                return ptr;
            }
            case .None => return null;
        }
    }

    fn alloc_zeroed(&self, size: usize) void* {
		const ptr = self->alloc(size);

		if (ptr != null) {
			@memset(ptr, 0, size);
		}

		return ptr;
    }

    pub fn reset(&self) {
        var current = self->nodes.head;
        while (current->next != null) {
            current->value.used = 0;
            current = current->next;
        }
    }

    pub fn destroy(&self) {
        while (self->nodes.head != null) {
            switch (self->nodes.pop_first()) {
                case .Some(node) => {
                    self->child_allocator.free(node->value.ptr);
                    self->child_allocator.free(node);
                }
                case .None => break;
            }
        }
    }

    fn create_node(&self, const capacity: usize) {
        var node: SinglyNode<ArenaNode>* =
            self->child_allocator.alloc(@sizeof(SinglyNode<ArenaNode>));

        const ptr = self->child_allocator.alloc(capacity);
        *node = SinglyNode {
            value: ArenaNode {
                ptr,
                capacity,
                used: 0
            },
            next: null
        };
        self->nodes.append(node);
    }

    fn ensure_capacity(&self, const size: usize) {
        switch (self->nodes.peek_first()) {
            case .Some(node) => {
                var arena = &node->value;

                if (arena->used + size > arena->capacity) {
                    self->create_node(node->value.capacity);
                }
            }
            case .None => @unreachable();
        }
    }

    fn realloc(&const self, ptr: void*, size: usize) void* {
        @panic("ArenaAllocator does not support realloc.");
    }

	fn free(&const self, ptr: void*) void {
        @panic("ArenaAllocator does not support free.");
    }
}
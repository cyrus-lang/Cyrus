import std::collections{Array};
import std::mem{Allocator};

pub struct Buffer<T> {
    buffer: Array<T>;

    pub inline fn new(const allocator: Allocator) Self {
        var buffer: Array<T> = Array.with_capacity(allocator, @sizeof(T));

        return Self { buffer };
    }

    pub inline fn with_capacity(const allocator: Allocator, cap: usize) Self {
        var buffer: Array<T> = Array.with_capacity(allocator, cap * @sizeof(T));

        return Self { buffer };
    }

    pub inline fn reserve(&self, const extra: usize) {
        const required = self->len() + extra + 1;

        if (required > self->cap()) {
            self->buffer.reserve(required);
        }
    }

    pub inline fn get(&self, index: usize) T {
        return self->data_ptr()[index];
    }

    pub inline fn data_ptr(&self) T* {
        return self->buffer.data_ptr();
    }

    pub inline fn cap(&const self) usize {
        return self->buffer.cap();
    }

    pub inline fn len(&const self) usize {
        return self->buffer.len();
    }

    pub inline fn push(&self, ch: T) {
        self->buffer.push(ch);
    }

    pub inline fn pop(&self) T {
        return self->buffer.pop();
    }

    pub inline fn is_empty(&const self) bool {
        return self->len() == 0;
    }

    pub inline fn clear(&self) {
        self->buffer.clear();
    }

    pub inline fn free(&self) {
        self->buffer.free();
    }
}
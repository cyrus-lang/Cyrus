import std::libc::types{c_file};
import std::errors{ErrorOr, ErrorStr};
import std::mem{Allocator};
import std::string{String};
import std::path{Path};
import std::libc;

pub struct File {
    path: Path*,
    file: c_file*,
    mode: OpeningModes,
    
    pub fn open(const path: const Path*, const mode: OpeningModes) ErrorOr<Self, ErrorStr> {        
        const path_str = path->as_string_const().as_str_const();
        const mode_str = mode.as_str();

        libc::printf("%s\n", path_str);

    	const file = libc::fopen(path_str, mode_str);
        if (!file) {
            return .Error("could not open the file");
        }

    	return .Value(Self {
            path,
            mode,
            file,
        });
    }

    pub fn flush(&const self) ErrorOr<(), ()> {
        const result = libc::fflush(self->file);
        if (result != 0) {
            return .Error(());
        }
        return .Value(());
    }

    pub fn remove(&const self) bool {
        const path_str = self->path->as_string_const().as_str_const();
        const result = libc::remove(path_str);
        return result == 0;
    }

    pub fn read(&const self, allocator: Allocator) ErrorOr<String, ErrorStr> {
        libc::fseek(self->file, 0, FileSeek.End.as_num());
        const size = @cast(usize, libc::ftell(self->file));
        libc::rewind(self->file);

        if (size < 0) {
            return .Error("failed to get file size");
        }

        var buffer: uint8* = allocator.alloc(size + 1);

        const read = libc::fread(buffer, 1, size, self->file);
        if (read != size) {
            return .Error("failed to read file");
        }

        buffer[size] = '\0';

        const content = String.from_str(allocator, buffer);
        allocator.free(buffer);

        return .Value(content);
    }

    pub fn write(&self, const content: const uint8*) ErrorOr<usize, ()> {
        const content_len = libc::strlen(content);

        const bytes = libc::fwrite(content, 1, content_len, self->file);
        if (bytes == 0) {
            return .Error(());
        } 

        return .Value(bytes);
    }

    pub fn append(&self, const content: const uint8*) ErrorOr<usize, ErrorStr> {
        switch (self->mode) {
            case .Append | .AppendBinary | .AppendRead | .AppendReadBinary => {}
            default => { return .Error("file not opened in append mode"); }
        }

        const result = libc::fseek(self->file, 0, FileSeek.End.as_num());
        if (result != 0) {
            return .Error("failed to seek to end of file for append");
        }
        
        const content_len = libc::strlen(content);

        const bytes = libc::fwrite(content, 1, content_len, self->file);
        if (bytes == 0) {
            return .Error("failed to append to file");
        }
        
        return .Value(bytes);
    }

    pub fn exists(const path: const Path*) bool {
        const path_str = path->as_string_const().as_str_const();
        const mode_str = OpeningModes.Read.as_str();

        const file = libc::fopen(path_str, mode_str);

        if (!file) {
            return false;
        } else {
            libc::fclose(file);
            return true;
        }
    }

    pub fn rename(const old_path: const Path*, const new_path: const Path*) ErrorOr<(), ()> {
        const old_path_str = old_path->as_string_const().as_str_const();
        const new_path_str = new_path->as_string_const().as_str_const();

        const result = libc::rename(old_path_str, new_path_str);
        if (result != 0) {
            return .Error(());
        }

        return .Value(());
    }

    pub inline fn eof(&const self) bool {
        return libc::feof(self->file) != 0;
    }

    pub inline fn close(&self) {
        libc::fclose(self->file);
    }
}

pub enum OpeningModes {
    Read,
    ReadBinary,
    Write,
    WriteBinary,
    Append,
    AppendBinary,
    ReadWrite,
    ReadWriteBinary,
    WriteRead,
    WriteReadBinary,
    AppendRead,
    AppendReadBinary,

    pub fn as_str(const self) const uint8* {
        switch (self) {
            case .Read => return "r";
            case .ReadBinary => return "rb";
            case .Write => return "w";
            case .WriteBinary => return "wb";
            case .Append => return "a";
            case .AppendBinary => return "ab";
            case .ReadWrite => return "r+";
            case .ReadWriteBinary => return "rb+";
            case .WriteRead => return "w+";
            case .WriteReadBinary => return "wb+";
            case .AppendRead => return "a+";
            case .AppendReadBinary => return "ab+";
        }
    }
}

pub enum FileSeek {
    Set = 0,
    Cur = 1,
    End = 2,

    pub inline fn as_num(const self) int32 {
        return @cast(int32, self);
    }
}

pub enum ExitStatusCode {
    Success = 0,
    Failure = 1,
    InvalidArgument = 2,
    FileNotFound = 3,
    PermissionDenied = 4,
    AllocationError = 5,
    FileOperationError = 6,
    
    pub fn as_num(const self) int32 {
        return @cast(int32, self);
    }
}

pub inline fn exit(code: ExitStatusCode) {
    libc::exit(code.as_num());
}

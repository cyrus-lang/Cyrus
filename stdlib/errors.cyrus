pub type ErrorStr = const char*;

pub enum ErrorOr<V> {
	Value(V),
	Error(ErrorStr)

    pub fn unwrap(&const self) V {
    	switch (*self) {
			case .Value(value) => {
				return value;
			}
			case .Error(err) => {
				@panic(err);
			}
		}
    }

	pub fn is_error(&const self) bool {
		switch (*self) {
			case .Value(_) => { return false; },
			case .Error(_) => { return true; }
		}
	}
}

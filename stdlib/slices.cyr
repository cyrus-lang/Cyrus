public struct Slice {
	public data: void*;
	public length: size_t;
	public element_size: size_t;

	public inline func index(self, idx: size_t) void* {
		#base = typecast(uintptr, self.data);
		#offset = typecast(uintptr, idx * self.element_size);
		#result = base + offset;
		return typecast(void*, result);
	}
}
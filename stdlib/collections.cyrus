import std::libc{printf, memmove, realloc, malloc, free};
import std::mem{Allocator};
import std::option{Option};
import std::iterator{Iterator};

const initial_array_capacity: usize = 16;

pub struct Vector<T> {
    data: T*;
    cap: usize;
    len: usize;

    /// Create a new array using a specific allocator.
    pub inline fn new(const allocator: Allocator) Self {
        const cap = initial_array_capacity;

        const data: T* = allocator.alloc(cap * @sizeof(T));

        if (!data) {
            @panic("allocation failed");
        }

        return Self {
            data,
            cap,
            len: 0,
        };
    }

    /// Pre-allocate memory to avoid initial reallocations.
    pub inline fn with_capacity(const allocator: Allocator, const cap: usize) Self {
        @debug() {
            @assert(cap != 0, "initial capacity cannot be zero");
        }

        const data: T* = allocator.alloc(cap * @sizeof(T));

        if (data == null) {
            @panic("initial allocation failed");
        }

        return Self { data, cap, len: 0 };
    }

    pub inline fn extend(&const self, const other: Self*) {
        if (self == other) {
            var original_len = self->len;

            self->reserve(original_len);
            
            memmove(
                // TODO: add integer overflow check 
                self->data + original_len,
                self->data,
                // TODO: add integer overflow check 
                original_len * @sizeof(T)
            );

            self->len += original_len;

            return;
        }

        self->extend_from_ptr(other->data, other->len);
    }

    pub inline fn extend_from_ptr(&const self, const ptr: T*, const count: usize) {
        if (count == 0) {
            return;
        }

        // TODO: add integer overflow check 
        // if (count > USIZE_MAX - self->len) {
        //     @panic("capacity overflow");
        // }

        const old_len = self->len;

        self->reserve(count);

        memmove(
            self->data + old_len,
            ptr,
            // TODO: add integer overflow check 
            count * @sizeof(T)
        );

        // TODO: add integer overflow check 
        self->len = old_len + count;
    }

    // FIXME: `Self` not found error.
    // /// Deep copy of the array
    // pub inline fn clone(&self) Self {
    //     var inst = Self.with_capacity(self->len);

    //     inst.extend_from_ptr(self->data, self->len);

    //     return inst;
    // }

    // TODO: from<V>(value: V)

    pub inline fn resize(&self, const len: usize, const value: T) {
        if (len > self->len) {
            self->reserve(len - self->len);

            while (self->len < len) {
                self->push(value);
            }
        } else {
            self->len = len;
        }
    }

    pub inline fn reserve(&self, const extra: usize) {
        const required = self->len + extra;

        if (required < self->len) {
            @panic("array capacity overflow");
        }
        
        // TODO: add integer overflow check 
        // if (extra > USIZE_MAX - self->len) {
        //     @panic("capacity overflow");
        // }

        if (required <= self->cap) {
            return;
        }

        self->grow(required);
    }

    pub inline fn push(&self, value: T) {
        self->reserve(1);

        self->data[self->len] = value;
        self->len++;
    }

    pub inline fn pop(&self) T {
        if (self->len == 0) {
            @panic("cannot pop from empty array");
        }

        self->len--;

        return self->data[self->len];
    }

    pub inline fn insert(&self, index: usize, value: T) {
        if (index > self->len) {
            @panic("insertion index out of bounds");
        }

        self->reserve(1);

        const src: T* = self->data + index;
        const dst: T* = self->data + index + 1;
        const count = self->len - index;

        memmove(dst, src, count * @sizeof(T));

        self->data[index] = value;
        self->len += 1;
    }

    /// Find the index of a value (Linear Search).
    pub inline fn index(&const self, const value: T) Option<usize> {
        for (var i: usize = 0; i < self->len; i++) {
            if (self->data[i] == value) {
                return .Some(i);
            }
        }

        return .None;
    }

    pub inline fn get(&const self, const index: usize) T {
        if (index >= self->len) {
            @panic("index out of bounds");
        }

        return *(self->data + index);
    }

    pub inline fn get_ref(&const self, const index: usize) T* {
        if (index >= self->len) {
            @panic("index out of bounds");
        }

        return self->data + index;
    }

    pub inline fn contains(&const self, const value: T) bool {
        // linear lookup
        for (var i: usize = 0; i < self->len; i++) {
            if (self->data[i] == value) {
                return true;
            }
        }

        return false;
    }

    pub inline fn get_unchecked(&const self, const index: usize) T* {
        return self->data + index;
    }

    pub inline fn len(&const self) usize {
        return self->len;
    }

    pub inline fn cap(&const self) usize {
        return self->cap;
    }

    pub inline fn is_empty(&const self) bool {
        return self->len == 0;
    }

    pub inline fn clear(&self) {
        self->len = 0;
    }

    pub inline fn reset(&self) {
        self->len = 0;
    }

    pub inline fn remove(&self, index: usize) T {
        if (index >= self->len) {
            @panic("index out of bounds");
        }

        const value = self->data[index];

        // TODO: add integer overflow check 
        const src = self->data + index + 1;
        const dst = self->data + index;

        const count = self->len - index - 1;

        memmove(dst, src, count * @sizeof(T));

        self->len--;

        return value;
    }

    pub inline fn data(&self) T* {
        return self->data;
    }

    pub inline fn data_const(&const self) const T* {
        return self->data;
    }

    pub inline fn free(&self) {
        if (self->data != null) {
            free(self->data);

            self->data = null;
            self->len = 0;
            self->cap = 0;
        }
    }

    // internals 

    fn grow(&self, min_cap: usize) {
        var new_cap: usize;

        if (self->cap == 0) {
            new_cap = initial_array_capacity;
        } else {
            new_cap = self->cap;
        }

        // exponential growth (2x)
        while (new_cap < min_cap) {
            // TODO: add integer overflow check 
            new_cap *= 2;
        }

        const new_data: T* = realloc(
            self->data,
            // TODO: add integer overflow check 
            new_cap * @sizeof(T)
        );

        if (new_data == null) {
            @panic("realloc failed");
        }

        self->data = new_data;
        self->cap = new_cap;
    }
}
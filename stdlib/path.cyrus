import std::libc{printf};
import std::string{String};
import std::mem{Allocator};
import std::option{Option};

/// POSIX ONLY!
pub struct Path {
    allocator: Allocator,
    inner: String,

    pub inline fn new(const allocator: Allocator, const name: uint8*) Self {
        const inner = String.from_str(allocator, name);

        return Self { allocator, inner };
    }

    /// POSIX ONLY!
    /// Get the parent directory (Everything before last `/`). Allocates new Path and returns it.
    pub fn parent(&self) Self {
        var last: usize;
        var found = false;

        const str = self->inner.as_str_const();
        const len = self->inner.len();

        if (str == null || len == 0) {
            return Path.new(self->allocator, ".");
        }

        for (var i: usize = 0; i < self->inner.len(); i++) {
            if (str[i] == separator()) {
                last = i;
                found = true;
            }
        }

        if (!found) {
            return Path.new(self->allocator, ".");
        }

        if (last == 0) {
            return Path.new(self->allocator, "/");
        }

        var parent = String.new(self->allocator);
        for (var i: usize = 0; i < last; i++) {
            parent.push(str[i]);
        }

        return Path {
            allocator: self->allocator, 
            inner: parent
        };
    }

    /// POSIX ONLY!
    /// Get the last component. Allocates new Path and returns it.
    pub fn file_name(&self) Self {
        const str = self->inner.as_str_const();
        const len = self->inner.len();

        if (str == null || len == 0) {
            return Path.new(self->allocator, ".");
        }

        var last: usize = len;
        
        // find the last separator
        for (var i: usize = 0; i < len; i++) {
            if (str[i] == separator()) {
                last = i + 1;
            }
        }
        
        // if no separator found or only trailing separators
        if (last >= len) {
            return Path.new(self->allocator, ".");
        }
        
        // extract the filename
        var file_name = String.new(self->allocator);
        for (var i: usize = last; i < len; i++) {
            file_name.push(str[i]);
        }
        
        return Self {
            allocator: self->allocator, 
            inner: file_name
        };
    }

    pub fn join(&const self, other: const Self*) Self {
        const self_str = self->inner.as_str_const();
        const self_len = self->inner.len();

        const other_str = other->inner.as_str_const();
        const other_len = other->inner.len();

        @assert(self_str, "self path string cannot be null");
        @assert(other_str, "other path string cannot be null");

        const self_ends_with_slash = self_len > 0 && self_str[self_len - 1] == separator();

        // if `other` is absolute, just return other
        if (other_len > 0 && other_str[0] == separator()) {
            const inner = String.from_str(self->allocator, other_str);
            
            return Self { allocator: self->allocator, inner };
        }

        var result = String.new(self->allocator);

        for (var i: usize = 0; i < self_len; i++) {
            result.push(self_str[i]);
        }

        if ((self_len > 0 && other_len > 0) && !self_ends_with_slash) {
            result.push(separator());
        }

        for (var i: usize = 0; i < other_len; i++) {
            result.push(other_str[i]);
        }

        return Self {
            allocator: self->allocator, 
            inner: result
        };
    }

    /// POSIX ONLY!
    /// Check if path has a dot.
    pub inline fn has_dot(&const self) bool {
        const str = self->inner.as_str_const();
        const len = self->inner.len();

        // only check up to 10 characters OR the actual length, whichever is smaller
        var check_len: usize;
        if (len < 10) { check_len = len; }
        else { check_len = 10; }

        for (var i: usize = 0; i < 10; i++) {
            if (str[i] == '.' && (i == 0 || str[i - 1] == separator())) {
                return true;
            }
        }

        return false;
    }

    /// POSIX ONLY!
    /// Check if path has ".." component.
    pub fn has_dot_dot(&const self) bool {
        const str = self->inner.as_str_const();
        const len = self->inner.len();
        
        if (len < 2) {
            return false;
        }

        for (var i: usize = 0; i < len - 1; i++) {
            if (str[i] == '.' && str[i + 1] == '.') {
                return true;
            }
        }

        return false;
    }

    /// POSIX ONLY!
    /// Check if path has a root `/`.
    pub inline fn has_root(&const self) bool {
        return self->inner.as_str_const()[0] == separator();
    }

    /// POSIX ONLY!
    /// Path is absolute if it starts with `/`.
    pub inline fn is_absolute(&const self) bool {
        return (!self->inner.is_empty()) && self->inner.as_str_const()[0] == separator();
    }

    /// POSIX ONLY!
    // Path is relative if it's not absolute.
    pub inline fn is_relative(&const self) bool {
        return !self->is_absolute();
    }

    pub inline fn as_string(&self) String {
        return self->inner;
    }

    pub inline fn as_string_const(&const self) const String {
        return self->inner;
    }

    pub inline fn free(&self) {
        self->inner.free();
    }
}

/// POSIX ONLY!
inline fn is_separator(ch: uint8) bool {
    return ch == '/';
}

/// POSIX ONLY!
inline fn separator() uint8 {
    return '/';
}
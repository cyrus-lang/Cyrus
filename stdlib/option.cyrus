pub enum Option<T> {
    Some(T),
    None

    pub inline fn is_some(&const self) bool {
        switch (*self) {
            case .Some(_) => return true;
            case .None => return false;
        }
    }

    pub inline fn is_none(&const self) bool {
        switch (*self) {
            case .Some(_) => return false;
            case .None => return true;
        }
    }

    pub inline fn unwrap(&const self) T {
        if (self->is_none()) {
            @panic("called `Option.unwrap()` on a `None` value");
        }

        switch (*self) {
            case .Some(value) => return value;
            default => @unreachable();
        }
    }
}
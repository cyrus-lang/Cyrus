import std::option{Option};

pub fn checked_add<T>(const a: T, const b: T) Option<T> {
    const is_signed = @cast(T, -1) < @cast(T, 0);
    if (is_signed) {
        const min = @cast(T, 1) << (@sizeof(T) * 8 - 1);
        const max = ~min;
        if (b > @cast(T, 0) && a > max - b) {
            return .None;
        }
        if (b < @cast(T, 0) && a < min - b) {
            return .None;
        }
    } else {
        if (a > @cast(T, -1) - b) {
            return .None;
        }
    }
    return .Some(a + b);
}

pub fn checked_sub<T>(const a: T, const b: T) Option<T> {
    const is_signed = @cast(T, -1) < @cast(T, 0);
    if (is_signed) {
        const min = @cast(T, 1) << (@sizeof(T) * 8 - 1);
        const max = ~min;
        if (b > @cast(T, 0) && a < min + b) {
            return .None;
        }
        if (b < @cast(T, 0) && a > max + b) {
            return .None;
        }
    } else {
        if (a < b) {
            return .None;
        }
    }
    return .Some(a - b);
}

pub fn checked_mul<T>(const a: T, const b: T) Option<T> {
    const is_signed = @cast(T, -1) < @cast(T, 0);
    if (is_signed) {
        const min = @cast(T, 1) << (@sizeof(T) * 8 - 1);
        const max = ~min;
        if (a > @cast(T, 0)) {
            if (b > @cast(T, 0)) {
                if (a > max / b) {
                    return .None;
                }
            } else {
                if (b < min / a) {
                    return .None;
                }
            }
        } else {
            if (b > @cast(T, 0)) {
                if (a < min / b) {
                    return .None;
                }
            } else {
                if (a != @cast(T, 0) && b < max / a) {
                    return .None;
                }
            }
        }
    } else {
        if (a != @cast(T, 0) && b > @cast(T, -1) / a) {
            return .None;
        }
    }
    return .Some(a * b);
}

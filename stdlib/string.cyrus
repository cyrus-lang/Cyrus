import std::libc{strlen, strcmp, memmove, isspace, tolower, toupper, printf};
import std::mem{Allocator};
import std::collections{Vector};

pub struct String {
    vec: Vector<char>,

    pub fn new(const allocator: Allocator) Self {
        var vec: Vector<char> = Vector.new(allocator);

        vec.push('\0'); // null-terminated

        return Self { vec };
    }

    pub fn with_capacity(const allocator: Allocator, const cap: usize) Self {
        var vec: Vector<char> = Vector.with_capacity(allocator, cap);

        vec.push('\0');
        
        return Self { vec };
    }

    pub fn from_str(const allocator: Allocator, const str: const char*) Self {
        @assert(str != null, "input string cannot be null");

        const len = strlen(str);

        var vec: Vector<char> = Vector.new(allocator);

        for (var i: usize = 0; i < len; i++) {
            vec.push(str[i]);
        }

        vec.push('\0');
        
        return Self { vec };
    }

    // TODO: Add method: From slice.

    pub fn reserve(&self, const extra: usize) {
        const required = self->len() + extra + 1;
        
        if (required > self->cap()) {
            self->vec.reserve(required);
        }
    }

    pub fn push(&self, const ch: char) {        
        var data = self->vec.data();
        var current = &data[self->len()];

        *current = ch;

        self->vec.push('\0');
    }

    pub fn push_str(&self, const str: char*) {
        @assert(str != null, "input string cannot be null");

        const len = strlen(str);

        self->vec.pop();

        self->reserve(len);

        for (var i: usize = 0; i < len; i++) {
            self->vec.push(str[i]);
        }
        
        self->vec.push('\0');
    }
    
    // TODO: Add method: replace

    pub inline fn trim(&self) {
        self->trim_start();
        self->trim_end();
    }

    pub fn trim_start(&self) {
        const str = self->as_str_const();
        const len = self->vec.len();

        var start: usize = 0;
        while (start < len - 1 && isspace(str[start]) != 0) {
            start++;
        }

        if (start == 0) {
            return;
        }

        if (start >= len - 1) {
            self->clear();
            return;
        }

        const n = len - start;
        memmove(@cast(void*, str), @cast(void*, str + start), n);

        while (start > 0) {
            self->vec.pop();
            start--;
        }
    }

    pub fn trim_end(&self) {
        const str = self->as_str_const();
        var len = self->len();

        if (len <= 1) {
            return;
        }

        while (len > 1 && isspace(str[len - 1]) != 0) {
            self->vec.pop();
            len--;
        }
    }

    pub fn to_lower(&self) {
        var str = self->as_str();

        for (var i: usize = 0; i < self->vec.len(); i++) {
            str[i] = @cast(char, tolower(str[i]));
        }
    }

    pub fn to_upper(&self) {
        var str = self->as_str();

        for (var i: usize = 0; i < self->vec.len(); i++) {
            str[i] = @cast(char, toupper(str[i]));
        }
    }

    pub inline fn as_str(&self) char* {
        return self->vec.data();
    }

    pub inline fn as_str_const(&const self) const char* {
        return self->vec.data_const();
    }

    pub inline fn is_empty(&const self) bool {
        return self->len() == 0;
    }

    pub inline fn cap(&const self) usize {
        return self->vec.cap();
    }

    pub inline fn len(&const self) usize {
        return self->vec.len() - 1; // exclude '\0'
    }

    pub inline fn eq(&const self, other: Self*) bool {
        return strcmp(self->as_str_const(), other->as_str_const()) == 0;
    }

    pub inline fn clear(&self) {
        self->vec.clear();
        self->vec.push('\0');
    }

    pub inline fn free(&self) {
        self->vec.free();
    }
}
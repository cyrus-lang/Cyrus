import std::libc{strlen};
import std::mem{Allocator};
import std::mem::buffer{Buffer};
import std::collections{Array};

pub struct String {
    buffer: Buffer<char>;

    pub inline fn new(allocator: Allocator) Self {
        const buffer: Buffer<char> = Buffer.new(allocator);

        buffer.push('\0'); // null-terminated

        return Self { buffer };
    }

    pub inline fn reserve(&self, extra: usize) {
        const required = self->len() + extra + 1;

        if (required > self->cap()) {
            self->buffer.reserve(required);
        }
    }

    pub inline fn as_str(&self) char* {
        return self->buffer.data_ptr();
    }

    pub inline fn push(&self, ch: char) {
        self->buffer.pop();
        self->reserve(1);
        self->buffer.push(ch);
        self->buffer.push('\0');
    }

    pub inline fn push_str(&self, str: char*) {
        @assert(str != null, "input string cannot be null");

        const len = strlen(str);

        self->buffer.pop();

        self->reserve(len);

        for (var i: usize = 0; i < len; i++) {
            self->buffer.push(str[i]);
        }
        
        self->push('\0');
    }

    pub inline fn is_empty(&self) bool {
        return self->len() == 0;
    }

    pub inline fn cap(&self) usize {
        return self->buffer.cap();
    }

    pub inline fn len(&self) usize {
        return self->buffer.len() - 1; // exclude '\0'
    }

    pub inline fn clear(&self) {
        self->buffer.clear();
        self->buffer.push('\0');
    }

    pub inline fn free(&self) {
        self->buffer.free();
    }
}
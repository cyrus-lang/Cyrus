import std::core{panic};
import std::libc{strlen, malloc, memcpy, free};

pub struct String {
    pub data: char*;
    pub length: size_t;
    pub capacity: size_t;

    pub fn new(init: const char*) String {
        var len = strlen(init);
        var cap = len + 1;
        var inst: String;
        inst.data = malloc(cap);
        if (!inst.data) {
            panic("failed to allocate memory for string.");
        }
        memcpy(inst.data, init, len + 1);
        inst.length = len;
        inst.capacity = cap;
        return inst;
    }

    pub fn free(&self) {
        free(self->data);
        self->data = null;
        self->length = 0;
        self->capacity = 0;
    }

    pub fn c_str(&self) char* {
        return cast(char*, self->data);
    }
}
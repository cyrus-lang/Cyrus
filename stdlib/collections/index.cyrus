pub struct Map<K, V> {
    entries: Vector<(K, V)>,

    pub inline fn new(const allocator: Allocator) Self {
        return Self { entries: Vector.new(allocator) };
    }

    pub fn set(&self, const key: K, const value: V) bool {
        if (self->get(key).is_some()) {
            return false;
        }

        self->entries.push((key, value));
        return true;
    }

    pub fn get(&const self, const key: K) Option<V> {
        const len = self->entries.len();
        const data = self->entries.data_const();

        // linear search
        for (var i: usize = 0; i < len; i++) {
            const item = data[i];
            
            if (item.0 == key) {
                return .Some(item.1);
            }
        }

        return .None;
    }

    pub inline fn free(&self) {
        self->entries.free();
    }
}